# ── GitHub App authentication (recommended for installable usage) ──
# Find the App ID on your GitHub App settings page (numeric).
GITHUB_APP_ID=123456

# Path to the .pem private key downloaded from GitHub App settings.
# Use either GITHUB_APP_PRIVATE_KEY_PATH or GITHUB_APP_PRIVATE_KEY, not both.
GITHUB_APP_PRIVATE_KEY_PATH=./github-app-private-key.pem

# Alternative: paste the full PEM contents here (with \n line breaks) if you cannot mount a file.
GITHUB_APP_PRIVATE_KEY=

# Optional: only needed for manual API calls. Webhooks send this automatically.
GITHUB_APP_INSTALLATION_ID=

# ── Webhook security ──
# Must match the webhook secret configured in your GitHub App settings.
GITHUB_WEBHOOK_SECRET=replace_with_a_random_webhook_secret

# ── Legacy personal token (optional local/manual fallback) ──
# If set, PR comments appear as the token owner, not the bot.
GITHUB_TOKEN=

# ── Model provider ──
# OpenAI-compatible chat completions API key (Groq, OpenAI, etc.).
HF_API_TOKEN=replace_with_your_model_provider_token

# Model identifier passed to the completions endpoint.
HF_MODEL_ID=llama-3.3-70b-versatile

# Base URL for the chat completions endpoint (must end before /chat/completions).
HF_API_BASE_URL=https://api.groq.com/openai/v1

# ── Review limits ──
MAX_REVIEW_CHUNKS=50
MAX_TOKENS_PER_CHUNK=2000
MAX_AGENT_CONCURRENCY=6
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_RETRIES=3

# ── Cost estimate ──
COST_PER_1K_TOKENS=0.0001

# ── Behavior ──
# Set to false to run reviews without posting to GitHub.
POST_GITHUB_COMMENT=true

# Set to true to run with mock AI responses (no API key needed).
MOCK_AI=false
