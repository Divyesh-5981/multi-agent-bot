GITHUB_TOKEN=ghp_replace_with_your_github_token
GITHUB_WEBHOOK_SECRET=replace_with_a_random_webhook_secret

# ── GitHub App auth (recommended — comments appear as a bot) ──
# Create a GitHub App, install it on your repo, and fill these in.
# When set, these take priority over GITHUB_TOKEN.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./your-app.private-key.pem
GITHUB_APP_INSTALLATION_ID=
API_TOKEN=gsk_replace_with_your_groq_api_key
MODEL_ID=llama-3.3-70b-versatile
API_BASE_URL=https://api.groq.com/openai/v1
SYNTHESIZER_MODEL_ID=llama-3.3-70b-versatile
MAX_REVIEW_CHUNKS=50
MAX_TOKENS_PER_CHUNK=2000
MAX_AGENT_CONCURRENCY=6
AGENT_TIMEOUT_SECONDS=60
AGENT_MAX_RETRIES=3
COST_PER_1K_TOKENS=0.0
POST_GITHUB_COMMENT=true
MOCK_AI=false
